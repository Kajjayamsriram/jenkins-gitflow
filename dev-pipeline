pipeline {
    agent any
    tools {
        maven 'mymaven'
    }
    environment {
        version = '8.7.1'
    }
    stages {
        stage ('code') {
            steps {
                git branch: 'feature/ui-update', url: 'https://github.com/Kajjayamsriram/jenkins-gitflow.git'
            }
        }
        stage ('build') {
            steps {
                sh "mvn clean install"
            }
        }
        stage ('deploy') {
            steps {
                deploy adapters: [tomcat9(alternativeDeploymentContext: '', credentialsId: 'tomcat-auth', path: '', url: 'http://35.173.222.208:8080')], contextPath: 'v-ecom', war: 'target/*.war'
            }
        }
    }
}
